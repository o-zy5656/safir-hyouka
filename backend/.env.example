# 開発用（PostgreSQL 未導入時）: SQLite を使用
DATABASE_URL=sqlite:///./safir_hyouka.db

# 本番・Docker 利用時はこちらに切り替え
# DATABASE_URL=postgresql+psycopg://safir:safir@127.0.0.1:5432/safir_hyouka

# 本番では必ず変更（openssl rand -hex 32）
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 本番は false（開発用の提出取消を無効化）
DEV_ALLOW_UNSUBMIT=true

# 社員 Excel 取込時の初期パスワード
DEFAULT_EMPLOYEE_PASSWORD=changeme123

# 管理画面アクセス（名簿取込時）: 施設長は評価者2＋管理画面の両方
ADMIN_JOB_TITLES=施設長
# EVAL1_LEADER_TITLES=リーダー,サブリーダー
# HQ_EVALUATOR_EMPLOYEE_ID=hq001
# HQ_EVALUATOR_DISPLAY_NAME=本部
# RETIRED_ARCHIVES_DIR=data/retired_employees
# 本番は true（起動時に SECRET_KEY 等を検証）
PRODUCTION_MODE=false

# 名簿取込のデフォルト施設
DEFAULT_FACILITY_FILTER=サフィールいなは

# テンプレート JSON のディレクトリ（backend からの相対パス）
TEMPLATES_DIR=templates

# 施設マスタ（backend/data/facilities.json）。施設追加・賞与シート名はここで設定
# FACILITIES_CONFIG_PATH=data/facilities.json

# 賞与 Excel への考課反映（秀成会 R7 夏季賞与など）
# BONUS_WORKBOOK_TEMPLATE_PATH=/Users/.../【秀成会】R7.夏季賞与(確定）.xlsx
# BONUS_WORKBOOK_PASSWORD=7770
# BONUS_NAME_ALIASES={"i3016":"渡邊　昌代","i3026":"ニン　イ　イ","i3025":"キン　ダンダリー"}
# BONUS_AUTO_RANK_ORDER=true
# BONUS_AUTO_RANK_GRADE=true
# BONUS_RANK_GRADE_RULES=A:0.10,B:0.20,C:0.40,D:0.20,E:0.10
# 賞与合計の社保込み計算（例: 0.15 = 15%）
# BONUS_SOCIAL_INSURANCE_RATE=0.15

# 開発時のみ（本番は nginx 同一オリジンのため通常不要）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
