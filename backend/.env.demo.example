# 課題提出用デモ API（Railway / Render 等）— 架空データのみ
# 本番・社内サーバーでは backend/.env.example を使用

DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
SECRET_KEY=generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEV_ALLOW_UNSUBMIT=true
DEFAULT_EMPLOYEE_PASSWORD=pass123

# Railway デプロイ時: 空 DB にデモデータを自動投入
AUTO_SEED_DEMO=true

# 公開デモ: ログイン不要のゲストアクセス・Excel なしで賞与表 API を有効化
DEMO_MODE=true
DEMO_GUEST_EMPLOYEE_ID=ADMIN001

# デモ用施設マスタ（仮名施設名）
FACILITIES_CONFIG_PATH=data/facilities.demo.json

# 賞与 Excel はデモでは不要（名簿ベースで行生成）
BONUS_WORKBOOK_TEMPLATE_PATH=
BONUS_NAME_ALIASES={}

# Vercel の URL を追加（カンマ区切り）
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

TEMPLATES_DIR=templates
